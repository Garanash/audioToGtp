# ============================================================
# Firebase Authentication — куда вставить токены
# ============================================================
# 1. Скопируйте этот файл в .env:  cp .env.example .env
# 2. Создайте проект на https://console.firebase.google.com
# 3. Project settings → Your apps → добавьте веб-приложение
# 4. Скопируйте значения из конфига Firebase в переменные ниже
# 5. Authentication → Sign-in method → включите:
#    - Email/Password (для регистрации через почту)
#    - Google (опционально)
# 6. Перезапустите: npm run dev
# ============================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================
# OAuth: Яндекс
# ============================================================
# Яндекс: https://oauth.yandex.ru → создать приложение
# Redirect URI: https://musicvibe.ru/api/auth/yandex/callback
# Firebase Service Account: Console → Project settings → Service accounts → Generate new private key
# ============================================================

# Production (musicvibe.ru)
AUTH_REDIRECT_BASE=https://musicvibe.ru/api
FRONTEND_URL=https://musicvibe.ru

# Яндекс OAuth (Redirect URI: https://musicvibe.ru/api/auth/yandex/callback)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Google OAuth (Redirect URI: https://musicvibe.ru/api/auth/google/callback)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Admin SDK — JSON сервисного аккаунта (для custom token)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
