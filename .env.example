# Вход через Google: настройка Firebase
# 1. Скопируйте этот файл в .env:  cp .env.example .env
# 2. Создайте проект на https://console.firebase.google.com
# 3. В Project settings → Your apps добавьте веб-приложение и скопируйте сюда значения
# 4. Authentication → Sign-in method → включите "Google"
# 5. Перезапустите dev-сервер (npm run dev)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
